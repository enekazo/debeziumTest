# Fabric Open Mirroring sink configuration
#
# SETUP:
#   cp application-oracle.properties.template application-oracle.properties
#   Fill in all <placeholder> values with your own credentials.
#   Set environment variables before starting:
#     export ORACLE_PASSWORD="<your-oracle-password>"
#     export AZURE_CLIENT_SECRET="<your-service-principal-secret>"
# ─────────────────────────────────────────────────────────────────────────────
debezium.sink.type=fabric

# ── OneLake landing zone ──────────────────────────────────────────────────────
# ABFS URI: abfss://<workspaceId>@onelake.dfs.fabric.microsoft.com/<itemId>/Files/LandingZone
# workspaceId — GUID from the Fabric portal URL for your workspace
# itemId      — GUID of the Mirrored Database item
fabric.landing.baseUri=abfss://<workspaceId>@onelake.dfs.fabric.microsoft.com/<itemId>/Files/LandingZone

# Authentication: Entra ID service principal
fabric.landing.auth=service-principal
fabric.sp.tenantId=<your-entra-tenant-id>
fabric.sp.clientId=<your-service-principal-client-id>
# Secret is read from the AZURE_CLIENT_SECRET environment variable — never commit the raw value.
fabric.sp.clientSecret=${AZURE_CLIENT_SECRET}

# Flush settings
fabric.flush.maxBytes=1073741824
fabric.flush.maxRecords=200000
fabric.flush.intervalMs=10000

# Parquet settings
fabric.parquet.compression=SNAPPY
fabric.rowMarker.column=__rowMarker__

# Sequence state file
fabric.sequence.stateFileName=_sequence.txt

# Oracle JDBC settings — connect to ORCLPDB1 to fetch table/column metadata
fabric.oracle.jdbcUrl=jdbc:oracle:thin:@//oracle-db:1521/ORCLPDB1
fabric.oracle.username=c##dbzuser
fabric.oracle.password=${ORACLE_PASSWORD}
fabric.oracle.metadata.refreshIntervalMs=300000
fabric.oracle.fetchRowOnUpdate=true

# Debezium source (Oracle connector)
debezium.source.connector.class=io.debezium.connector.oracle.OracleConnector
debezium.source.database.hostname=oracle-db
debezium.source.database.port=1521
debezium.source.database.user=c##dbzuser
debezium.source.database.password=${ORACLE_PASSWORD}
debezium.source.database.dbname=FREE
debezium.source.database.pdb.name=ORCLPDB1

# Use file-based schema history — no Kafka required
debezium.source.schema.history.internal=io.debezium.storage.file.history.FileSchemaHistory
debezium.source.schema.history.internal.file.filename=/debezium/data/schemahistory.dat

debezium.source.include.schema.changes=false
debezium.source.topic.prefix=oracle
debezium.source.schema.include.list=HR
debezium.source.table.include.list=HR.EMPLOYEES,HR.DEPARTMENTS
debezium.source.time.precision.mode=connect
debezium.source.decimal.handling.mode=double

# Offset storage
debezium.source.offset.storage=org.apache.kafka.connect.storage.FileOffsetBackingStore
debezium.source.offset.storage.file.filename=/debezium/data/offsets.dat
debezium.source.offset.flush.interval.ms=1000
